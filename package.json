{
  "name": "eventhub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"cyan,magenta\" \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "setup": "npm install --prefix backend && npm install --prefix frontend",
    "seed": "npm run seed --prefix backend",
    "migrate": "cd backend && npx prisma migrate dev",
    "db:push": "cd backend && npx prisma db push",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report",
    "test:bdd": "npx cucumber-js",
    "booking-management-pomtest": "npx playwright test tests/booking-management.specPO.spec.js",
    "smoke": "npx playwright test --grep @smoke",
    "booking-management-pomtest-ddt": "npx playwright test tests/booking-management.specPO-ddt.spec.js",
    "booking-management-pomtest-ddt-ts": "npx playwright test tests/booking-management.specPO-ddt.spec.ts",
    "booking-management-cucumber": "npx cucumber-js features/booking-management.feature --format html:cucumber-report.html",
    "regression": "npx playwright test --grep @regression"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "concurrently": "^9.1.2"
  }
}
